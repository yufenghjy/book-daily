---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BookCard from "../components/BookCard.astro";
import DateNavigation from "../components/DateNavigation.astro";
import { getDailyBook, getTodayStr } from "../lib/daily";
import booksData from "../data/books.json";

const today = getTodayStr();
const book = getDailyBook(booksData, today);
---

<BaseLayout
  title={`今日推荐：《${book.title}》 - 每日一书`}
  description={`${book.title}，${book.author} 著 —— ${book.reason}`}
  ogImage={book.cover}
  ogUrl="https://yufenghjy.github.io/book-daily"
>
  <Header />

  <main class="px-6 lg:px-12 py-10 max-w-6xl mx-auto">
    <div class="mb-8 flex items-center gap-3">
      <span class="text-3xl">📖</span>
      <div>
        <p class="text-xs text-amber-600/60 dark:text-amber-400/50 uppercase tracking-widest font-medium">
          Today's Pick
        </p>
        <p class="text-lg font-bold text-amber-800 dark:text-amber-200">
          {today} · 今日推荐
        </p>
      </div>
    </div>

    <BookCard book={book} date={today} />

    <DateNavigation date={today} />
  </main>

  <Footer />
</BaseLayout>
