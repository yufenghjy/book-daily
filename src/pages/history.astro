---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HistoryCalendar from "../components/HistoryCalendar";
import booksData from "../data/books.json";

const base = import.meta.env.BASE_URL;
const today = new Date();
const year = today.getFullYear();
const month = today.getMonth() + 1;
---

<BaseLayout
  title="往期回顾 - 每日一书"
  description="浏览每日一书的所有历史推荐，查看过去每一天推荐的好书。"
  ogUrl="https://yufenghjy.github.io/book-daily/history"
>
  <Header />

  <main class="px-6 lg:px-12 py-10 max-w-6xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-amber-800 dark:text-amber-200 mb-2">📅 往期回顾</h1>
      <p class="text-amber-700/60 dark:text-amber-400/40">
        点击日历中的日期，查看当天的推荐书籍
      </p>
    </div>

    <div class="content-card rounded-2xl p-6 md:p-8 shadow-xl shadow-amber-900/5 dark:shadow-black/30">
      <HistoryCalendar
        client:load
        books={booksData}
        initialYear={year}
        initialMonth={month}
        base={base}
      />
    </div>
  </main>

  <Footer />
</BaseLayout>
