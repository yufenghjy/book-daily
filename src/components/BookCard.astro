---
import type { Book } from "../lib/daily";
import { formatDateCN } from "../lib/daily";
import ShareButton from "./ShareButton";

export interface Props {
  book: Book;
  date?: string;
}

const { book, date } = Astro.props;
---

<div
  class="flex flex-col md:flex-row gap-6 p-6 md:p-8 rounded-2xl
         bg-white dark:bg-gray-800 shadow-lg shadow-gray-200/50
         dark:shadow-gray-900/50"
>
  <!-- Cover -->
  <div class="flex-shrink-0 mx-auto md:mx-0 w-40 md:w-48">
    <img
      src={book.cover}
      alt={`${book.title} 封面`}
      class="w-full rounded-lg shadow-md"
      loading="eager"
      decoding="async"
      onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';"
    />
    <!-- Fallback when cover image fails to load -->
    <div
      class="hidden w-full aspect-[3/4] rounded-lg bg-gray-200 dark:bg-gray-700
             items-center justify-center text-4xl font-bold text-gray-400
             dark:text-gray-500"
      style="display: none;"
    >
      {book.title[0]}
    </div>
  </div>

  <!-- Details -->
  <div class="flex-1 flex flex-col gap-3">
    <!-- Category badge -->
    <span
      class="self-start px-2.5 py-0.5 text-xs font-medium rounded-full
             bg-blue-50 dark:bg-blue-900/40 text-blue-700
             dark:text-blue-300"
    >
      {book.category}
    </span>

    <!-- Title -->
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
      {book.title}
    </h1>

    <!-- Author -->
    <p class="text-base text-gray-500 dark:text-gray-400">
      {book.author} 著
    </p>

    <!-- Description -->
    <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-sm md:text-base">
      {book.description}
    </p>

    <!-- Recommendation reason -->
    <blockquote
      class="pl-4 border-l-4 border-blue-500 italic
             text-gray-600 dark:text-gray-400 text-sm"
    >
      💡 {book.reason}
    </blockquote>

    <!-- Actions -->
    <div class="flex flex-wrap items-center gap-3 mt-2">
      {
        book.doubanUrl && (
          <a
            href={book.doubanUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm
                   text-green-600 dark:text-green-400
                   hover:underline"
          >
            在豆瓣查看 →
          </a>
        )
      }
      <ShareButton
        client:load
        title={book.title}
        date={date}
      />
    </div>
  </div>

  <!-- Date badge -->
  {
    date && (
      <div
        class="hidden md:block absolute top-4 right-4 text-xs text-gray-400
               dark:text-gray-500"
      >
        {formatDateCN(date)}
      </div>
    )
  }
</div>
