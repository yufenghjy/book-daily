---
import { addDays } from "../lib/date";
import { getTodayStr } from "../lib/daily";

export interface Props {
  date: string;
}

const { date } = Astro.props;
const today = getTodayStr();
const prev = addDays(date, -1);
const next = addDays(date, 1);
const showNext = next <= today;
const base = import.meta.env.BASE_URL;
---

<div class="flex justify-between items-center mt-6 text-sm">
  <a
    href={`${base}/${prev}`}
    class="flex items-center gap-1 text-amber-700/60 dark:text-amber-300/50
           hover:text-amber-800 dark:hover:text-amber-200 transition-colors font-medium"
  >
    ← {prev}
  </a>
  <a
    href={base}
    class="text-amber-700/60 dark:text-amber-300/50
           hover:text-amber-800 dark:hover:text-amber-200 transition-colors font-medium"
  >
    回到今天
  </a>
  {showNext ? (
    <a
      href={`${base}/${next}`}
      class="flex items-center gap-1 text-amber-700/60 dark:text-amber-300/50
             hover:text-amber-800 dark:hover:text-amber-200 transition-colors font-medium"
    >
      {next} →
    </a>
  ) : (
    <span class="flex items-center gap-1 text-amber-400/40 dark:text-amber-600/30 cursor-not-allowed">
      已是今天
    </span>
  )}
</div>
